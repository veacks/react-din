{
  "name": "@din/editor-mcp-server",
  "private": true,
  "version": "0.1.0",
  "description": "Local MCP server for DIN Editor live and offline control",
  "type": "module",
  "scripts": {
    "build": "node --enable-source-maps ../../node_modules/tsup/dist/cli-default.js --config tsup.config.ts",
    "start:raw": "node --enable-source-maps dist/index.cjs",
    "start": "npm run build && npm run start:raw",
    "dev": "npm run start",
    "test": "node ../../node_modules/vitest/vitest.mjs --config vitest.config.ts",
    "test:run": "node ../../node_modules/vitest/vitest.mjs --config vitest.config.ts --run"
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
