{
  "name": "@open-din/react",
  "version": "0.1.0",
  "description": "A React-first declarative WebAudio library for building audio graphs",
  "author": "Valentin Dubois - veacks.net",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./nodes": {
      "import": {
        "types": "./dist/nodes/index.d.ts",
        "default": "./dist/nodes/index.js"
      },
      "require": {
        "types": "./dist/nodes/index.d.cts",
        "default": "./dist/nodes/index.cjs"
      }
    },
    "./transport": {
      "import": {
        "types": "./dist/transport/index.d.ts",
        "default": "./dist/transport/index.js"
      },
      "require": {
        "types": "./dist/transport/index.d.cts",
        "default": "./dist/transport/index.cjs"
      }
    },
    "./sequencer": {
      "import": {
        "types": "./dist/sequencer/index.d.ts",
        "default": "./dist/sequencer/index.js"
      },
      "require": {
        "types": "./dist/sequencer/index.d.cts",
        "default": "./dist/sequencer/index.cjs"
      }
    },
    "./analyzers": {
      "import": {
        "types": "./dist/analyzers/index.d.ts",
        "default": "./dist/analyzers/index.js"
      },
      "require": {
        "types": "./dist/analyzers/index.d.cts",
        "default": "./dist/analyzers/index.cjs"
      }
    },
    "./sources": {
      "import": {
        "types": "./dist/sources/index.d.ts",
        "default": "./dist/sources/index.js"
      },
      "require": {
        "types": "./dist/sources/index.d.cts",
        "default": "./dist/sources/index.cjs"
      }
    },
    "./effects": {
      "import": {
        "types": "./dist/effects/index.d.ts",
        "default": "./dist/effects/index.js"
      },
      "require": {
        "types": "./dist/effects/index.d.cts",
        "default": "./dist/effects/index.cjs"
      }
    },
    "./midi": {
      "import": {
        "types": "./dist/midi/index.d.ts",
        "default": "./dist/midi/index.js"
      },
      "require": {
        "types": "./dist/midi/index.d.cts",
        "default": "./dist/midi/index.cjs"
      }
    },
    "./data": {
      "import": {
        "types": "./dist/data/index.d.ts",
        "default": "./dist/data/index.js"
      },
      "require": {
        "types": "./dist/data/index.d.cts",
        "default": "./dist/data/index.cjs"
      }
    },
    "./patch": {
      "import": {
        "types": "./dist/patch/index.d.ts",
        "default": "./dist/patch/index.js"
      },
      "require": {
        "types": "./dist/patch/index.d.cts",
        "default": "./dist/patch/index.cjs"
      }
    },
    "./routing": {
      "import": {
        "types": "./dist/routing/index.d.ts",
        "default": "./dist/routing/index.js"
      },
      "require": {
        "types": "./dist/routing/index.d.cts",
        "default": "./dist/routing/index.cjs"
      }
    },
    "./notes": {
      "import": {
        "types": "./dist/notes/index.d.ts",
        "default": "./dist/notes/index.js"
      },
      "require": {
        "types": "./dist/notes/index.d.cts",
        "default": "./dist/notes/index.cjs"
      }
    },
    "./synths": {
      "import": {
        "types": "./dist/synths/index.d.ts",
        "default": "./dist/synths/index.js"
      },
      "require": {
        "types": "./dist/synths/index.d.cts",
        "default": "./dist/synths/index.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      },
      "require": {
        "types": "./dist/utils/index.d.cts",
        "default": "./dist/utils/index.cjs"
      }
    },
    "./patch/schema.json": "./schemas/patch.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:library",
    "test:library": "vitest --config vitest.config.ts --run",
    "test:library:watch": "vitest --config vitest.config.ts",
    "validate:docs": "node ./scripts/validate-docs.mjs",
    "validate:patch-schema": "node ./scripts/validate-patch-schema.mjs",
    "validate:coverage": "node ./scripts/validate-coverage.mjs",
    "validate:changes": "node ./scripts/validate-changes.mjs",
    "ci:check": "npm run validate:docs && npm run validate:patch-schema && npm run validate:coverage && npm run test:library",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "example:dev": "npm --prefix example run dev",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "react",
    "webaudio",
    "audio",
    "declarative",
    "dsp",
    "music",
    "sequencer",
    "synthesizer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/veacks/react-din.git"
  },
  "bugs": {
    "url": "https://github.com/veacks/react-din/issues"
  },
  "homepage": "https://github.com/veacks/react-din#readme"
}
